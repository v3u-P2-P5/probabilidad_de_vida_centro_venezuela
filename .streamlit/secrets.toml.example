# ──────────────────────────────────────────────────────────────────────────────
# PLANTILLA DE SECRETS — este archivo SÍ se versiona (sin claves reales).
#
# USO LOCAL
#   1. Copia este archivo:  cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Abre .streamlit/secrets.toml y reemplaza los valores con tus claves reales.
#   3. NUNCA commitees secrets.toml  (ya está en .gitignore).
#
# USO EN STREAMLIT CLOUD
#   En el panel de tu app: ⋮ → Settings → Secrets
#   Pega el bloque TOML con los valores reales. Streamlit lo cifra y nunca
#   queda en el repositorio.
#
# DÓNDE OBTENER LA CLAVE
#   Regístrate en https://openrouter.ai → Account → API Keys → Create key
# ──────────────────────────────────────────────────────────────────────────────

OPENROUTER_API_KEY    = "PON_AQUI_TU_CLAVE_sk-or-v1-..."
OPENROUTER_APP_URL    = "https://probabilidad-vida-venezuela.streamlit.app"
OPENROUTER_APP_TITLE  = "Venezuela 2026 — Doble Sismo"
