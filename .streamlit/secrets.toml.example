# Plantilla de secretos — copia este archivo a `.streamlit/secrets.toml` y rellena tu clave.
# `secrets.toml` está en .gitignore y NUNCA debe subirse al repo.
#
# En Streamlit Community Cloud: Settings → Secrets → pega el mismo contenido.
# En Docker: monta el archivo o usa la variable de entorno OPENROUTER_API_KEY.

# Clave de OpenRouter (https://openrouter.ai/keys). Sin ella, el Asistente se auto-deshabilita.
OPENROUTER_API_KEY = "sk-or-v1-..."

# Opcionales: identifican la app ante OpenRouter (aparecen en su panel de uso).
OPENROUTER_APP_URL = "https://tu-app.streamlit.app"
OPENROUTER_APP_TITLE = "Venezuela 2026 — Doble Sismo"
